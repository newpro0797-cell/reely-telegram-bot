# ============================================
# Reely — Environment Variables
# ============================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Server-side AI API keys (shared by all users)
GEMINI_API_KEY=your-gemini-api-key
MODAL_ZIMAGE_ENDPOINT=https://your-modal-endpoint.modal.run
MODAL_KOKORO_ENDPOINT=https://your-modal-endpoint.modal.run

# Frontend vars (Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Leave empty for Vercel (same-origin). For Docker, set to http://localhost:3000
VITE_API_URL=

# CORS (Docker mode)
FRONTEND_URL=http://localhost:5173

# Telegram Integration
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
